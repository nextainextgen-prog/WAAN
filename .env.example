# Changoh System — ตัวอย่างค่า environment (คัดลอกเป็น .env แล้วเติมค่าจริง)

# ฐานข้อมูล SQLite (local)
DATABASE_URL="file:./changoh.db"

# JWT secret สำหรับ session (ใส่ค่าสุ่มยาวๆ)
AUTH_SECRET="change-me-to-a-long-random-string"

# Claude CLI (ใช้ Max subscription — ไม่ใช้ API key) ต้อง login ด้วย: claude
CLAUDE_CLI_PATH="claude"

# Gemini CLI (ทางเลือก — login ด้วยบัญชี Google)
GEMINI_CLI_PATH="gemini"

# โมเดลสมองเริ่มต้น: claude | gemini | hermes | auto
BRAIN_DEFAULT_MODEL="claude"

# Telegram Bot (จาก @BotFather)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_CHAT_ID=""

# Hermes agent เดิม (ใส่ URL webhook เช่น n8n)
HERMES_WEBHOOK_URL=""
HERMES_AUTH_HEADER=""

# Obsidian vault เดิม — AI เขียนเฉพาะโฟลเดอร์ AI, อ่านเฉพาะโฟลเดอร์งานที่อนุญาต
OBSIDIAN_VAULT_PATH=""
OBSIDIAN_AI_FOLDER="AI-Changoh"
OBSIDIAN_WORK_FOLDERS=""

# โฟลเดอร์ในเครื่องที่เฝ้าดูเอกสารใหม่ (ทางเลือกแทน Drive API)
WATCH_FOLDER=""

# ===== Google Drive API (ต่อ Drive จริง) =====
# 1) สร้าง OAuth Desktop client ใน Google Cloud → ดาวน์โหลดเป็น credentials.json
# 2) npm run drive:auth (อนุญาตในเบราว์เซอร์) 3) npm run drive:watch
DRIVE_INBOX_FOLDER_ID=""
DRIVE_SIGNED_FOLDER_ID=""
DRIVE_CREDENTIALS_PATH="credentials.json"
DRIVE_TOKEN_PATH=".drive-token.json"
DRIVE_POLL_SECONDS="20"

# ลายเซ็นสำหรับเซ็นเอกสาร (PNG โปร่งใส) — ค่าเริ่มต้น public/signature.png
SIGNATURE_IMAGE_PATH=""

# token ภายในให้ Telegram poller / watcher เรียก API (ใส่ค่าสุ่ม)
INTERNAL_API_TOKEN="change-me-random"

# URL ของแอป (สำหรับ scripts)
APP_URL="http://localhost:3000"
