# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Changoh: local data & generated output (do not commit)
/.generated
*.db
/prisma/*.db
/src/generated
# personal signature image (user provides their own)
/public/signature.png

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Google Drive OAuth secrets
credentials.json
.drive-token.json

# runtime logs
.run-logs/

# thunder admin session
.thunder-session.json
.generated/

# oho session
.oho-session.json

# facebook / line OA sessions (login cookies — do not commit)
.fb-session.json
.line-session.json

# stray debug log
aff-debug.log
