// Changoh System — Prisma schema (SQLite, local-first)
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

// ทุนวิจัย — โครงสร้างยืดหยุ่นรองรับข้อมูลดิบ (field ว่างได้)
model Grant {
  id          String    @id @default(cuid())
  projectName String                       // ชื่อโครงการ
  ownerName   String?                       // อาจารย์เจ้าของทุน
  source      String?                       // แหล่งทุน (TRF, สกสว, ฯลฯ)
  amount      Float     @default(0)          // มูลค่าทุน (บาท)
  status      String    @default("submitted") // สถานะปัจจุบัน (key)
  nextDeadline DateTime?                     // deadline งวดถัดไป
  note        String?                        // หมายเหตุ
  orderIndex  Int       @default(0)          // ลำดับใน Kanban column
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// เป้า OKR ต่อปี
model OkrTarget {
  id           String @id @default(cuid())
  year         Int    @unique
  targetAmount Float  @default(10000000)
}

// สไตล์สไลด์ที่อาจารย์สอนผ่านแชท (Style Memory)
model StyleMemory {
  id        String   @id @default(cuid())
  label     String   @default("default")
  content   String                          // ข้อความอธิบายสไตล์เป็นภาษาไทย
  updatedAt DateTime @updatedAt
}

// ประวัติแชทเลขา AI
model ChatMessage {
  id        String   @id @default(cuid())
  role      String                          // user | assistant
  content   String
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

// ทีมงานที่น้องวานรู้จัก (สำหรับสิทธิ์การใช้ + จดจำ + แท็ก)
model TeamMember {
  id             String   @id @default(cuid())
  telegramUserId String   @unique
  name           String
  username       String?
  role           String?
  notes          String?  // ประวัติ/ข้อมูลที่เจ้าของบอกให้จำ
  canUseBot      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// เอกสารในไปป์ไลน์อนุมัติ/เซ็น
model Document {
  id         String   @id @default(cuid())
  filename   String
  source     String?               // ที่มา เช่น ชื่อโฟลเดอร์/ผู้ส่ง
  mimeType   String?
  filePath   String                // path ไฟล์ต้นฉบับ (ในเครื่อง)
  signedPath String?               // path ไฟล์ที่เซ็นแล้ว
  summary    String?               // สรุปโดย Claude
  status     String   @default("pending") // pending | approved | rejected
  decidedAt  DateTime?
  driveFileId   String?            // id ไฟล์ต้นทางบน Google Drive
  driveUploaded Boolean  @default(false) // อัปไฟล์ที่เซ็นแล้วกลับ Drive หรือยัง
  createdAt  DateTime @default(now())
}

// ตารางงาน/ปฏิทิน — น้องวานจดสิ่งที่ต้องทำตามวัน แล้วแจ้งเตือนเมื่อถึงวัน
model CalendarEvent {
  id          String    @id @default(cuid())
  chatId      String                          // แชทที่ให้ลง (แจ้งเตือนกลับที่นี่)
  date        DateTime                         // วันของงาน (เที่ยงคืนของวันนั้น เวลาไทย)
  timeText    String?                          // เวลาถ้าระบุ เช่น "14:00"
  title       String                           // สิ่งที่ต้องทำ
  emoji       String?                          // อิโมจิที่ผู้ใช้กำหนด
  createdById String?
  creatorName String?
  notified    Boolean   @default(false)        // แจ้งเตือนถึงวันแล้วหรือยัง
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([notified, date])
}

// บันทึกสิ่งที่น้องวานทำ/เฝ้า (append-only) — ให้วานตอบย้อนหลังได้ว่าทำอะไรไป + รายงานสุขภาพตัวเอง
model BotActivity {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  source      String                            // oho | fb | line | usage | aff | thunder | bot
  kind        String                            // waiting-alert | close-remind | watch-close | aff-check | expiry | usage-alert | popup-dismiss | session-expired | tick-error ...
  severity    String   @default("info")         // info | warn | error (self-report สุขภาพ)
  company     String?                            // แบรนด์/บริษัท
  platform    String?                            // line | fb | oho
  channel     String?                            // ชื่อ OA/เพจ
  customer    String?
  admin       String?                            // แอดมินที่รับ/ลืมปิดเคส (assignedName)
  shiftNames  String?                            // แอดมินเวรตอนนั้น
  convId      String?
  chatId      String?                            // กลุ่ม Telegram ปลายทาง
  level       Int?                               // ระดับ escalation
  waitSec     Int?
  requestedBy String?                            // คนสั่ง (aff/thunder)
  outcome     String?                            // passed/failed, จำนวน ฯลฯ
  summary     String                             // ประโยคเดียวอ่านรู้เรื่อง (ฉีดเข้า prompt)
  payload     String?                            // JSON เสริม

  @@index([createdAt])
  @@index([kind, createdAt])
  @@index([source, createdAt])
}
